---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import WhatsappIcon from "../components/WhatsappIcon.astro";
import SectionDivider from "../components/SectionDivider.astro";
---

<Layout title="Contacto | OLMEWARE">
  <main class="bg-[#0A0806]">

    <!-- Hero -->
    <section class="relative pt-40 pb-12 px-6 md:px-20 lg:px-44 bg-gradient-to-b from-[#0A0806] via-[#0D1A0D] to-[#0A0806]">
      <div class="absolute top-24 left-8 w-10 h-10 border-t border-l border-[rgba(201,135,42,0.4)]"></div>
      <div class="max-w-3xl" data-reveal="up">
        <span class="text-xs font-mono tracking-widest uppercase text-[#C9872A]">/ Hablemos</span>
        <h1 class="font-dm text-5xl md:text-7xl text-[#F0E4C8] mt-4 leading-tight">
          Cuéntanos tu <span class="text-[#27A870]">proyecto</span>
        </h1>
      </div>
    </section>

    <SectionDivider text="Contacto" />

    <!-- Contact content -->
    <section class="py-16 px-6 md:px-14 lg:px-20 pb-28">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: info -->
        <div class="flex flex-col justify-start" data-reveal="left">
          <span class="text-xs font-bold tracking-[0.2em] text-[#C9872A] uppercase mb-4">— Estamos para ayudarte —</span>
          <h2 class="font-dm text-3xl md:text-4xl text-[#F0E4C8] mb-5">Trabajemos juntos</h2>
          <p class="text-[#8A7560] text-base leading-relaxed max-w-sm mb-10">
            Sin compromisos, sin vendehumos. Solo una conversación honesta sobre cómo podemos ayudarte a crecer con tecnología.
          </p>

          <!-- Contact chips -->
          <div class="flex flex-col gap-3 mb-10">
            <div class="contact-chip">
              <span class="contact-dot"></span>
              <a href="tel:528448580335" class="text-sm md:text-base font-bold text-[#F0E4C8] hover:text-[#27A870] transition-colors">
                +52 (844) 858-0335
              </a>
            </div>
            <div class="contact-chip">
              <span class="contact-dot"></span>
              <a href="mailto:hola@olmeware.tech" class="text-sm md:text-base font-bold text-[#F0E4C8] hover:text-[#27A870] transition-colors">
                hola@olmeware.tech
              </a>
            </div>
            <div class="contact-chip">
              <span class="contact-dot"></span>
              <span class="text-sm text-[#8A7560]">Saltillo, Coahuila · México</span>
            </div>
            <div class="contact-chip">
              <span class="contact-dot"></span>
              <span class="text-sm text-[#8A7560]">Lunes a domingo, 8:00 – 20:00</span>
            </div>
          </div>

          <!-- Quick contact options -->
          <div class="flex flex-col gap-3">
            <a href="https://wa.me/5218448580335" target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-3 p-4 border border-[rgba(39,168,112,0.2)] rounded-sm hover:border-[rgba(39,168,112,0.5)] bg-[rgba(39,168,112,0.04)] hover:bg-[rgba(39,168,112,0.08)] transition-all">
              <svg class="w-5 h-5 text-[#27A870] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              <div>
                <p class="text-xs text-[#8A7560] uppercase tracking-widest font-mono">WhatsApp</p>
                <p class="text-sm font-semibold text-[#F0E4C8]">Escríbenos ahora</p>
              </div>
            </a>
            <a href="mailto:hola@olmeware.tech"
              class="flex items-center gap-3 p-4 border border-[rgba(201,135,42,0.2)] rounded-sm hover:border-[rgba(201,135,42,0.5)] bg-[rgba(201,135,42,0.04)] hover:bg-[rgba(201,135,42,0.08)] transition-all">
              <svg class="w-5 h-5 text-[#C9872A] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <div>
                <p class="text-xs text-[#8A7560] uppercase tracking-widest font-mono">Email</p>
                <p class="text-sm font-semibold text-[#F0E4C8]">hola@olmeware.tech</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Right: form -->
        <div data-reveal="right" data-reveal-delay="0.12">
          <form
            class="space-y-5"
            action="https://api.web3forms.com/submit"
            method="POST"
          >
            <input type="hidden" name="access_key" value="39bfccfa-f50e-4534-bdff-9ed17d6da6fb" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="form-group">
                <label class="form-label" for="name">Nombre</label>
                <input type="text" id="name" name="name" required class="form-input" placeholder="Tu nombre" />
              </div>
              <div class="form-group">
                <label class="form-label" for="apellido">Apellido</label>
                <input type="text" id="apellido" name="apellido" required class="form-input" placeholder="Tu apellido" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="form-group">
                <label class="form-label" for="empresa">Empresa</label>
                <input type="text" id="empresa" name="empresa" required class="form-input" placeholder="Nombre de la empresa" />
              </div>
              <div class="form-group">
                <label class="form-label" for="cargo">Cargo</label>
                <input type="text" id="cargo" name="cargo" required class="form-input" placeholder="Tu puesto" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="form-group">
                <label class="form-label" for="email">Correo</label>
                <input type="email" id="email" name="email" required class="form-input" placeholder="tu@email.com" />
              </div>
              <div class="form-group">
                <label class="form-label" for="telefono">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" required class="form-input" placeholder="+52 (844) 000-0000" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="mensaje">Mensaje</label>
              <textarea id="mensaje" name="mensaje" rows="5" required class="form-input resize-none" placeholder="Cuéntanos sobre tu proyecto..."></textarea>
            </div>

            <button type="submit" class="submit-btn">
              Enviar mensaje
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </section>

    <Footer />
    <WhatsappIcon />
  </main>
</Layout>
