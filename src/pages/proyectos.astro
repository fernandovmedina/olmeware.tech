---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import WhatsappIcon from "../components/WhatsappIcon.astro";
import SectionDivider from "../components/SectionDivider.astro";
import { projects } from "../const/projects";
import type { Project } from "../const/projects";

const defaultProject: Project = projects[0];
---

<Layout title="Proyectos | OLMEWARE">
  <main class="bg-[#0A0806]">

    <!-- Hero -->
    <section class="relative pt-40 pb-20 px-6 md:px-20 lg:px-44 bg-gradient-to-b from-[#0A0806] via-[#0D1A0D] to-[#0A0806]">
      <div class="absolute top-24 left-8 w-10 h-10 border-t border-l border-[rgba(201,135,42,0.4)]"></div>
      <div class="absolute bottom-8 right-8 w-10 h-10 border-b border-r border-[rgba(201,135,42,0.4)]"></div>
      <div class="max-w-3xl" data-reveal="up">
        <span class="text-xs font-mono tracking-widest uppercase text-[#C9872A]">/ Casos de éxito</span>
        <h1 class="font-dm text-5xl md:text-7xl text-[#F0E4C8] mt-4 leading-tight">
          Proyectos <span class="text-[#27A870]">exitosos</span>
        </h1>
        <p class="text-[#8A7560] mt-5 text-lg leading-relaxed max-w-xl">
          Cada proyecto es una solución personalizada. Descubre cómo hemos ayudado a empresas a optimizar sus procesos y crecer con tecnología.
        </p>
      </div>
    </section>

    <SectionDivider text="Nuestros Proyectos" />

    <!-- Projects list + detail panel -->
    <section class="py-16 px-6 md:px-14 lg:px-20">
      <div class="max-w-7xl mx-auto">

        <!-- Single source of truth for JS -->
        <div id="projects-data" data-projects={JSON.stringify(projects)} class="hidden" aria-hidden="true"></div>

        <div class="proj-layout">

          <!-- Left: numbered list -->
          <div class="proj-list" data-reveal-stagger="up" data-stagger-delay="0.07">
            {projects.map((p: Project, i: number) => (
              <button
                class="proj-list-item"
                data-reveal-child
                data-project-id={p.id}
                style={`--pc: ${p.color}; --pcr: ${p.colorRgb};`}
                aria-label={`Ver ${p.name}`}
              >
                <span class="proj-item-num">{String(i + 1).padStart(2, "0")}</span>
                <div class="proj-item-body">
                  <span class="proj-item-name">{p.name}</span>
                  <span class="proj-item-sub">{p.client} · {p.type}</span>
                </div>
                <span class="proj-item-status" style={`color:${p.statusColor};border-color:${p.statusColor}40;background:${p.statusColor}15;`}>
                  {p.status}
                </span>
                <svg class="proj-item-arrow" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            ))}
          </div>

          <!-- Right: detail panel -->
          <div
            id="project-details"
            class="proj-detail"
            style={`--pc: ${defaultProject.color}; --pcr: ${defaultProject.colorRgb};`}
            data-reveal="right" data-reveal-delay="0.15"
          >
            <div class="proj-detail-wash" aria-hidden="true"></div>
            <div class="proj-detail-num" id="project-num" aria-hidden="true">
              {String(projects.findIndex(p => p.id === defaultProject.id) + 1).padStart(2, "0")}
            </div>
            <div class="proj-detail-content">
              <div class="proj-detail-top">
                <span id="project-type" class="proj-detail-type">{defaultProject.type}</span>
                <span
                  class="proj-detail-status"
                  id="project-status"
                  style={`color:${defaultProject.statusColor};border-color:${defaultProject.statusColor}40;background:${defaultProject.statusColor}15;`}
                >
                  {defaultProject.status}
                </span>
              </div>
              <div class="proj-detail-name-wrap">
                <h3 class="proj-detail-name" id="project-name" style={`color: ${defaultProject.color}`}>
                  {defaultProject.name}
                </h3>
              </div>
              <p class="proj-detail-client" id="project-client">{defaultProject.client}</p>
              <div class="proj-detail-divider" style={`background: linear-gradient(90deg, ${defaultProject.color}, transparent);`} id="project-divider"></div>
              <p class="proj-detail-desc" id="project-description">{defaultProject.longDescription}</p>
              <div class="proj-detail-tech" id="project-technologies">
                {defaultProject.technologies.map((t: string) => (
                  <span class="proj-tech-pill" style={`background:rgba(${defaultProject.colorRgb},0.1);color:${defaultProject.color};border-color:rgba(${defaultProject.colorRgb},0.25);`}>
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative py-28 px-6 text-center overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#0A0806] via-[#0D1A0D] to-[#0A0806]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] rounded-full bg-[radial-gradient(circle,rgba(27,122,82,0.08)_0%,transparent_70%)]"></div>
      <div class="relative z-10 max-w-xl mx-auto">
        <span class="text-xs font-mono tracking-widest uppercase text-[#8A7560]" data-reveal="fade">¿Tienes un proyecto en mente?</span>
        <h2 class="font-dm text-4xl md:text-5xl text-[#F0E4C8] my-5" data-reveal="up" data-reveal-delay="0.1">
          Hagámoslo <span class="text-[#27A870]">realidad</span>
        </h2>
        <a href="/contacto" class="inline-flex items-center gap-3 px-10 py-4 bg-[#1B7A52] text-[#F0E4C8] font-bold text-sm tracking-widest uppercase rounded-sm hover:bg-[#27A870] transition-colors border border-[rgba(27,122,82,0.5)]" data-reveal="up" data-reveal-delay="0.2">
          Solicitar Demo →
        </a>
      </div>
    </section>

    <Footer />
    <WhatsappIcon />
  </main>
</Layout>

<style>
  .proj-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 1023px) { .proj-layout { grid-template-columns: 1fr; } }

  .proj-list { display: flex; flex-direction: column; gap: 0; }

  .proj-list-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    background: transparent;
    cursor: none; text-align: left;
    transition: background 0.25s, padding-left 0.25s;
    width: 100%; position: relative;
  }
  .proj-list-item::before {
    content: ""; position: absolute;
    left: 0; top: 0; bottom: 0; width: 0;
    background: var(--pc);
    border-radius: 0 2px 2px 0;
    transition: width 0.25s ease;
  }
  .proj-list-item:hover, .proj-list-item.active {
    background: rgba(var(--pcr), 0.05);
    padding-left: 1.25rem;
  }
  .proj-list-item:hover::before, .proj-list-item.active::before { width: 3px; }
  .proj-list-item:first-child { border-top: 1px solid rgba(255,255,255,0.04); }

  .proj-item-num {
    font-family: var(--font-dm);
    font-size: 0.85rem;
    color: rgba(240,228,200,0.2);
    flex-shrink: 0; width: 1.8rem;
    transition: color 0.25s;
  }
  .proj-list-item:hover .proj-item-num,
  .proj-list-item.active .proj-item-num { color: var(--pc); }

  .proj-item-body { flex: 1; display: flex; flex-direction: column; gap: 0.2rem; min-width: 0; }
  .proj-item-name { font-size: 0.95rem; font-weight: 700; color: #F0E4C8; line-height: 1.2; }
  .proj-item-sub  { font-size: 0.7rem; color: rgba(240,228,200,0.3); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .proj-item-status {
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 0.2rem 0.5rem;
    border-radius: 999px; border: 1px solid; white-space: nowrap; flex-shrink: 0;
  }

  .proj-item-arrow {
    width: 1rem; height: 1rem;
    color: rgba(240,228,200,0.2); flex-shrink: 0;
    transition: color 0.25s, transform 0.25s;
  }
  .proj-list-item:hover .proj-item-arrow,
  .proj-list-item.active .proj-item-arrow { color: var(--pc); transform: translateX(3px); }

  /* Detail panel */
  .proj-detail {
    position: relative; border-radius: 1.5rem;
    border: 1.5px solid rgba(255,255,255,0.06);
    overflow: hidden; min-height: 26rem;
    display: flex; flex-direction: column;
  }
  .proj-detail-wash {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 100% 80% at 100% 100%, rgba(var(--pcr), 0.1) 0%, transparent 60%);
    pointer-events: none; transition: background 0.4s;
  }
  .proj-detail-num {
    position: absolute; right: -0.5rem; bottom: -2rem;
    font-family: var(--font-dm);
    font-size: clamp(7rem, 18vw, 14rem);
    font-weight: 400; color: var(--pc); opacity: 0.05;
    line-height: 1; pointer-events: none; user-select: none;
    letter-spacing: -0.05em; z-index: 0; transition: color 0.4s;
  }
  .proj-detail-content {
    position: relative; z-index: 1;
    padding: 2rem 2.25rem;
    display: flex; flex-direction: column; gap: 1.1rem; flex: 1;
  }
  .proj-detail-top {
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;
  }
  .proj-detail-type {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: rgba(240,228,200,0.4);
  }
  .proj-detail-status {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 0.25rem 0.65rem;
    border-radius: 999px; border: 1px solid;
  }
  .proj-detail-name-wrap { overflow: hidden; }
  .proj-detail-name {
    font-family: var(--font-dm);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 400; line-height: 1; letter-spacing: -0.03em;
    transition: color 0.3s;
  }
  .proj-detail-client {
    font-size: 0.82rem; color: rgba(240,228,200,0.4); font-style: italic;
  }
  .proj-detail-divider { height: 1px; width: 100%; opacity: 0.25; }
  .proj-detail-desc {
    font-size: 0.9rem; color: rgba(240,228,200,0.55); line-height: 1.7; flex: 1;
  }
  .proj-detail-tech { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .proj-tech-pill {
    font-size: 0.72rem; font-weight: 600;
    padding: 0.3rem 0.65rem; border-radius: 0.4rem; border: 1px solid;
    transition: opacity 0.2s;
  }
  .proj-tech-pill:hover { opacity: 0.75; }

  @media (max-width: 1023px) { .proj-detail { min-height: auto; } }
</style>

<script>
  import { gsap } from "gsap";

  interface Project {
    id: number; name: string; client: string; type: string;
    longDescription: string; technologies: string[];
    status: string; statusColor: string; color: string; colorRgb: string;
  }

  document.addEventListener("DOMContentLoaded", () => {
    const dataEl = document.getElementById("projects-data");
    if (!dataEl) return;
    const projects: Project[] = JSON.parse(dataEl.dataset.projects ?? "[]");

    const items    = document.querySelectorAll<HTMLElement>(".proj-list-item");
    const details  = document.getElementById("project-details");
    const nameEl   = document.getElementById("project-name");
    const numEl    = document.getElementById("project-num");
    const typeEl   = document.getElementById("project-type");
    const statusEl = document.getElementById("project-status");
    const clientEl = document.getElementById("project-client");
    const descEl   = document.getElementById("project-description");
    const techEl   = document.getElementById("project-technologies");
    const divEl    = document.getElementById("project-divider");

    function setActive(id: number) {
      items.forEach(i => i.classList.toggle("active", i.dataset.projectId === String(id)));
    }

    function updateDetails(project: Project, index: number) {
      setActive(project.id);
      gsap.to(".proj-detail-content", {
        opacity: 0, y: 10, duration: 0.2, ease: "power2.in",
        onComplete: () => {
          details?.style.setProperty("--pc", project.color);
          details?.style.setProperty("--pcr", project.colorRgb);
          if (numEl)    numEl.textContent = String(index + 1).padStart(2, "0");
          if (nameEl)   { nameEl.textContent = project.name; nameEl.style.color = project.color; }
          if (typeEl)   typeEl.textContent = project.type;
          if (clientEl) clientEl.textContent = project.client;
          if (divEl)    divEl.style.background = `linear-gradient(90deg, ${project.color}, transparent)`;
          if (statusEl) {
            statusEl.textContent = project.status;
            statusEl.style.color = project.statusColor;
            statusEl.style.borderColor = `${project.statusColor}40`;
            statusEl.style.background = `${project.statusColor}15`;
          }
          if (descEl) descEl.textContent = project.longDescription;
          if (techEl) {
            techEl.innerHTML = project.technologies.map(t =>
              `<span class="proj-tech-pill" style="background:rgba(${project.colorRgb},0.1);color:${project.color};border-color:rgba(${project.colorRgb},0.25);">${t}</span>`
            ).join("");
          }
          gsap.to(".proj-detail-content", { opacity: 1, y: 0, duration: 0.25, ease: "power2.out" });
        },
      });
    }

    items.forEach((item) => {
      item.addEventListener("click", () => {
        const id  = parseInt(item.dataset.projectId ?? "0");
        const idx = projects.findIndex(p => p.id === id);
        if (projects[idx]) updateDetails(projects[idx], idx);
      });
      item.addEventListener("mouseenter", () => gsap.to(item, { x: 2, duration: 0.2 }));
      item.addEventListener("mouseleave", () => gsap.to(item, { x: 0, duration: 0.2 }));
    });

    setActive(1);
  });
</script>
