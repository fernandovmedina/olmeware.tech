<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap');

  :root {
    --font-display: 'Syne', sans-serif;
    --font-mono: 'Space Mono', monospace;
    --font-body: 'DM Sans', sans-serif;
    --jade: #27A870;
    --gold: #C9872A;
    --bg: #0A0806;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--bg);
  }

  .hero-headline, h1, h2, h3 {
    font-family: var(--font-display);
  }

  .font-mono, .tag, .stack-badge {
    font-family: var(--font-mono);
  }

  /* Jade + gold gradient text */
  .hero-gradient-text {
    background: linear-gradient(135deg, #27A870 0%, #C9872A 50%, #27A870 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
  }

  @keyframes shimmer {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  /* Aztec grid background */
  .hero-grid {
    background-image:
      linear-gradient(rgba(201,135,42,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,135,42,0.08) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.06; transform: scale(1); }
    50% { opacity: 0.12; transform: scale(1.05); }
  }
  @keyframes pulse-slow-2 {
    0%, 100% { opacity: 0.04; transform: scale(1.05); }
    50% { opacity: 0.10; transform: scale(1); }
  }
  @keyframes ping-slow {
    0% { transform: scale(1); opacity: 1; }
    75%, 100% { transform: scale(2); opacity: 0; }
  }
  @keyframes scroll-line {
    0% { opacity: 0; transform: scaleY(0); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
    100% { opacity: 0; transform: scaleY(1) translateY(100%); }
  }

  .animate-pulse-slow { animation: pulse-slow 6s ease-in-out infinite; }
  .animate-pulse-slow-2 { animation: pulse-slow-2 8s ease-in-out infinite; }
  .animate-ping-slow { animation: ping-slow 2s cubic-bezier(0,0,0.2,1) infinite; }
  .scroll-line { animation: scroll-line 2s ease-in-out infinite; }

  .tag {
    display: inline-block;
    padding: 2px 8px;
    font-size: 10px;
    letter-spacing: 0.05em;
    color: rgba(201, 135, 42, 0.8);
    border: 1px solid rgba(201, 135, 42, 0.2);
    border-radius: 2px;
    background: rgba(201, 135, 42, 0.06);
  }

  .stack-badge {
    display: inline-block;
    padding: 3px 8px;
    font-size: 10px;
    color: rgba(240, 228, 200, 0.45);
    border: 1px solid rgba(201, 135, 42, 0.1);
    border-radius: 2px;
    background: rgba(201, 135, 42, 0.04);
  }

  .service-card, .process-step {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .service-card.visible, .process-step.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('visible');
          }, i * 80);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('.service-card, .process-step').forEach(el => {
    observer.observe(el);
  });
</script>
