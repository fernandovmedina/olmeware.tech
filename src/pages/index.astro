---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import WhatsappIcon from "../components/WhatsappIcon.astro";
import SectionDivider from "../components/SectionDivider.astro";
import frontOlmecaHead from "../assets/front_olmeca_head.png";
---

<Layout>
  <main>

    <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
    <section class="relative overflow-hidden min-h-screen flex items-center px-6 md:px-20 lg:px-44 bg-gradient-to-b from-[#0A0806] via-[#0D1A0D] to-[#0A0806]">

      <!-- Orb glows -->
      <div class="hero-orb-jade" aria-hidden="true"></div>
      <div class="hero-orb-gold" aria-hidden="true"></div>

      <!-- Comet particles -->
      <div id="comet-container" class="absolute inset-0 pointer-events-none z-0"></div>

      <!-- Corner brackets -->
      <div class="absolute top-24 left-8 w-10 h-10 border-t border-l border-[rgba(201,135,42,0.4)]"></div>
      <div class="absolute bottom-24 right-8 w-10 h-10 border-b border-r border-[rgba(201,135,42,0.4)]"></div>

      <div class="relative z-10 w-full flex flex-col md:flex-row items-center gap-12 md:gap-8 pt-28 pb-16">

        <!-- Left: text -->
        <div class="w-full md:w-3/5 text-center md:text-left">
          <div id="hero-eyebrow" style="opacity:0;transform:translateY(20px)">
            <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 border border-[rgba(201,135,42,0.4)] rounded-full bg-[rgba(201,135,42,0.06)]">
              <span class="w-1.5 h-1.5 rounded-full bg-[#C9872A] animate-pulse"></span>
              <span class="text-[#C9872A] text-xs font-mono tracking-widest uppercase">Software · 100% Mexicano</span>
            </div>
          </div>

          <div class="overflow-hidden mb-2">
            <h1
              id="hero-title"
              class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black font-dm leading-[0.95] tracking-tight text-[#F0E4C8]"
              style="transform:translateY(100%)"
            >
              Construimos software
            </h1>
          </div>
          <div class="overflow-hidden mb-8">
            <h1
              id="hero-title-2"
              class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black font-dm leading-[0.95] tracking-tight hero-gradient-text"
              style="transform:translateY(100%)"
            >
              que transforma
            </h1>
          </div>

          <p
            id="hero-desc"
            class="text-base md:text-lg text-[#8A7560] leading-relaxed max-w-xl mb-10"
            style="opacity:0;transform:translateY(20px)"
          >
            Reducimos costos y aumentamos la eficiencia de tu empresa con soluciones a la medida.
            <span class="text-[rgba(240,228,200,0.7)]"> Automatización, IA y desarrollo personalizado.</span>
          </p>

          <div id="hero-cta" class="flex flex-col sm:flex-row items-center md:items-start gap-4" style="opacity:0;transform:translateY(20px)">
            <a href="/contacto" class="px-8 py-4 bg-[#1B7A52] text-[#F0E4C8] font-bold text-sm tracking-widest uppercase rounded-sm hover:bg-[#27A870] transition-colors border border-[rgba(27,122,82,0.5)]">
              Solicitar Demo
            </a>
            <a href="/proyectos" class="px-8 py-4 border border-[rgba(201,135,42,0.3)] text-[rgba(240,228,200,0.7)] font-medium text-sm tracking-widest uppercase rounded-sm hover:border-[rgba(201,135,42,0.6)] hover:text-[#C9872A] transition-all">
              Ver Proyectos →
            </a>
          </div>
        </div>

        <!-- Right: Olmeca head -->
        <div class="w-full md:w-2/5 flex justify-center" id="hero-image" style="opacity:0;transform:scale(0.9)">
          <Image
            src={frontOlmecaHead}
            alt="OLMEWARE — Cabeza Olmeca"
            width={480}
            height={480}
            class="w-auto max-h-[440px] object-contain drop-shadow-[0_0_60px_rgba(201,135,42,0.2)]"
          />
        </div>
      </div>

      <!-- Stats strip -->
      <div id="hero-stats" class="absolute bottom-8 left-0 right-0 px-6 md:px-20 lg:px-44" style="opacity:0">
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-x-10 gap-y-4 pt-6 border-t border-[rgba(201,135,42,0.1)]">
          <div class="text-center">
            <span class="block text-2xl font-black text-[#F0E4C8] font-dm">3</span>
            <span class="text-xs text-[#8A7560] tracking-widest uppercase font-mono">Clientes activos</span>
          </div>
          <div class="w-px h-8 bg-[rgba(201,135,42,0.2)] hidden sm:block"></div>
          <div class="text-center">
            <span class="block text-2xl font-black text-[#F0E4C8] font-dm">+$300K MXN</span>
            <span class="text-xs text-[#8A7560] tracking-widest uppercase font-mono">En proyectos</span>
          </div>
          <div class="w-px h-8 bg-[rgba(201,135,42,0.2)] hidden sm:block"></div>
          <div class="text-center">
            <span class="block text-2xl font-black text-[#F0E4C8] font-dm">40–70%</span>
            <span class="text-xs text-[#8A7560] tracking-widest uppercase font-mono">Mejora de eficiencia</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ COMPANIES ═══════════════════════════ -->
    <section class="py-16 px-6 md:px-20 lg:px-44">
      <p class="text-center text-xs font-mono tracking-widest uppercase text-[#8A7560] mb-8" data-reveal="fade">
        Empresas que confían en nosotros
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-12 sm:gap-16 md:gap-24" data-reveal-stagger="up" data-stagger-delay="0.1">
        <Image src="/companies/ag_maquinado.webp" alt="AG Maquinado" width={160} height={50} class="grayscale hover:grayscale-0 opacity-50 hover:opacity-90 transition-all" data-reveal-child />
        <Image src="/companies/alra_plastic.png" alt="ALRA Plastic" width={90} height={50} class="grayscale hover:grayscale-0 opacity-50 hover:opacity-90 transition-all" data-reveal-child />
        <Image src="/companies/mbs_construcciones.webp" alt="MBS Construcciones" width={160} height={50} class="grayscale hover:grayscale-0 opacity-50 hover:opacity-90 transition-all" data-reveal-child />
      </div>
    </section>

    <!-- ═══════════════════════════ SERVICIOS ═══════════════════════════ -->
    <SectionDivider text="Servicios" />

    <section class="py-20 px-6 md:px-14 lg:px-20">
      <div class="max-w-7xl mx-auto">
        <div class="mb-14">
          <span class="text-xs font-bold tracking-[0.2em] text-[#C9872A] uppercase" data-reveal="fade">— Lo que hacemos —</span>
          <h2 class="text-4xl md:text-5xl font-dm text-[#F0E4C8] mt-3" data-reveal="up" data-reveal-delay="0.1">
            Nuestros Servicios
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal-stagger="up" data-stagger-delay="0.07">
          {[
            { title: "Desarrollo Web", desc: "Aplicaciones web rápidas, seguras y escalables hechas a la medida.", color: "#27A870", colorRgb: "39,168,112", techs: ["React", "Node.js", "PostgreSQL"] },
            { title: "Apps Móviles", desc: "Experiencias nativas e híbridas para iOS y Android con sincronización en tiempo real.", color: "#C9872A", colorRgb: "201,135,42", techs: ["React Native", "Flutter"] },
            { title: "Automatización IoT", desc: "Sistemas IIoT que optimizan procesos industriales y reducen costos operativos.", color: "#E5A840", colorRgb: "229,168,64", techs: ["Python", "MQTT", "AWS IoT"] },
            { title: "Inteligencia Artificial", desc: "Modelos de IA aplicados a los procesos reales de tu negocio.", color: "#27A870", colorRgb: "39,168,112", techs: ["OpenAI", "TensorFlow", "Python"] },
            { title: "Cloud & DevOps", desc: "Infraestructura escalable en la nube con pipelines de CI/CD y monitoreo.", color: "#C9872A", colorRgb: "201,135,42", techs: ["AWS", "Docker", "Terraform"] },
            { title: "Consultoría TI", desc: "Asesoría estratégica para optimizar tu infraestructura tecnológica.", color: "#8B6B4A", colorRgb: "139,107,74", techs: ["Arquitectura", "Auditoría", "Roadmap"] },
          ].map(s => (
            <div
              class="service-card relative rounded-2xl border border-[rgba(255,255,255,0.06)] bg-[rgba(255,255,255,0.02)] overflow-hidden p-6 transition-all duration-300 hover:-translate-y-1"
              style={`--sc: ${s.color}; --scr: ${s.colorRgb};`}
              data-reveal-child
            >
              <div class="service-wash"></div>
              <div class="relative z-10">
                <h3 class="font-dm text-xl text-[#F0E4C8] mb-2">{s.title}</h3>
                <p class="text-sm text-[#8A7560] leading-relaxed mb-5">{s.desc}</p>
                <div class="flex flex-wrap gap-2">
                  {s.techs.map(t => (
                    <span class="text-[0.68rem] font-semibold px-2.5 py-1 rounded service-tag">{t}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-12" data-reveal="up" data-reveal-delay="0.1">
          <a href="/servicios" class="inline-flex items-center gap-2 text-sm font-semibold text-[#27A870] border border-[rgba(39,168,112,0.35)] px-6 py-3 rounded-sm hover:bg-[rgba(39,168,112,0.08)] transition-colors">
            Ver todos los servicios →
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ CASO DE ESTUDIO ═══════════════════════════ -->
    <SectionDivider text="Proyectos" />

    <section class="py-20 px-6 md:px-14 lg:px-20">
      <div class="max-w-7xl mx-auto">
        <div class="mb-14">
          <span class="text-xs font-bold tracking-[0.2em] text-[#C9872A] uppercase" data-reveal="fade">— Caso de éxito —</span>
          <h2 class="text-4xl md:text-5xl font-dm text-[#F0E4C8] mt-3" data-reveal="up" data-reveal-delay="0.1">
            Proyecto destacado
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <!-- Image -->
          <div data-reveal="left">
            <div class="relative">
              <img
                src="https://images.unsplash.com/photo-1556656793-08538906a9f8?w=800&q=80"
                alt="ALRA APP - Escaneo QR"
                class="rounded-2xl w-full h-72 md:h-96 object-cover border border-[rgba(39,168,112,0.2)]"
              />
              <div class="absolute -bottom-5 -right-5 bg-[#170E08] rounded-xl p-4 border border-[rgba(39,168,112,0.3)] shadow-2xl max-w-[180px]">
                <p class="text-xs text-[#8A7560]">Lote escaneado</p>
                <p class="font-bold text-[#27A870] font-dm">#LT-2/SL-5</p>
              </div>
            </div>
          </div>

          <!-- Text -->
          <div data-reveal="right" data-reveal-delay="0.1">
            <div class="inline-block text-xs font-semibold tracking-widest uppercase py-1 px-3 rounded-full mb-4 bg-[rgba(39,168,112,0.1)] text-[#27A870] border border-[rgba(39,168,112,0.25)]">
              App Móvil
            </div>
            <h3 class="font-dm text-3xl md:text-4xl text-[#F0E4C8] mb-2">ALRA APP</h3>
            <p class="text-sm text-[#8A7560] mb-5 italic">ALRA Plastic Recycling</p>
            <p class="text-[#8A7560] leading-relaxed mb-6">
              Trazabilidad completa de lotes de plástico reciclado mediante códigos QR únicos escaneados en cada etapa del proceso productivo. Control de calidad en tiempo real disponible en iOS y Android.
            </p>
            <ul class="space-y-3 mb-8">
              {["Información instantánea de cada lote procesado", "Historial completo de transformación", "Certificados digitales de calidad", "Transparencia total en la cadena de valor"].map(item => (
                <li class="flex items-start gap-3 text-sm text-[#8A7560]">
                  <span class="text-[#27A870] mt-0.5">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2 mb-8">
              {["React Native", "Supabase", "QR Generator", "Expo Go"].map(t => (
                <span class="text-xs font-semibold px-3 py-1 rounded border border-[rgba(39,168,112,0.25)] bg-[rgba(39,168,112,0.08)] text-[#27A870]">{t}</span>
              ))}
            </div>
            <a href="/proyectos" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1B7A52] text-[#F0E4C8] font-bold text-sm rounded-sm hover:bg-[#27A870] transition-colors">
              Ver todos los proyectos →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ CTA ═══════════════════════════ -->
    <section class="relative py-32 px-6 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#0A0806] via-[#0D1A0D] to-[#0A0806]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[300px] rounded-full bg-[radial-gradient(circle,rgba(27,122,82,0.1)_0%,transparent_70%)]"></div>
      <div class="relative z-10 max-w-xl mx-auto text-center">
        <span class="text-xs font-mono tracking-widest uppercase text-[#8A7560]" data-reveal="fade">¿Tienes un proyecto?</span>
        <h2 class="font-dm text-4xl md:text-6xl text-[#F0E4C8] my-5 leading-tight" data-reveal="up" data-reveal-delay="0.1">
          Hagámoslo <span class="text-[#27A870]">realidad</span>
        </h2>
        <p class="text-[#8A7560] mb-10 leading-relaxed" data-reveal="up" data-reveal-delay="0.2">
          Cuéntanos tu idea y construiremos la solución perfecta para tu negocio.
        </p>
        <a href="/contacto" class="inline-flex items-center gap-3 px-10 py-4 bg-[#1B7A52] text-[#F0E4C8] font-bold text-sm tracking-widest uppercase rounded-sm hover:bg-[#27A870] transition-colors border border-[rgba(27,122,82,0.5)]" data-reveal="up" data-reveal-delay="0.3">
          Solicitar Demo
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </section>

    <Footer />
    <WhatsappIcon />
  </main>
</Layout>

<style>
  /* Orb glows */
  .hero-orb-jade {
    position: absolute; border-radius: 50%; pointer-events: none;
    top: -10%; left: -10%; width: 40vw; height: 40vw;
    background: radial-gradient(circle, rgba(27,122,82,0.18) 0%, transparent 70%);
    filter: blur(70px);
    animation: orb-drift 12s ease-in-out infinite alternate;
  }
  .hero-orb-gold {
    position: absolute; border-radius: 50%; pointer-events: none;
    bottom: -15%; right: -15%; width: 50vw; height: 50vw;
    background: radial-gradient(circle, rgba(201,135,42,0.12) 0%, transparent 70%);
    filter: blur(90px);
    animation: orb-drift 16s ease-in-out infinite alternate-reverse;
  }
  @keyframes orb-drift {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(5%,5%) scale(1.1); }
  }

  /* Hero gradient text */
  .hero-gradient-text {
    background: linear-gradient(135deg, #27A870 0%, #C9872A 60%, #27A870 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 5s linear infinite;
  }
  @keyframes shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  /* Service cards */
  .service-wash {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 80% 70% at 110% 120%, rgba(var(--scr), 0.1) 0%, transparent 65%);
    opacity: 0.6; transition: opacity 0.3s;
  }
  .service-card:hover .service-wash { opacity: 1; }
  .service-card:hover { border-color: rgba(var(--scr), 0.3); }

  .service-tag {
    background: rgba(var(--scr), 0.1);
    color: var(--sc);
    border: 1px solid rgba(var(--scr), 0.25);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Comet particles
    const container = document.getElementById("comet-container");
    const createComet = () => {
      if (!container) return;
      const comet = document.createElement("div");
      const size = Math.random() * 4 + 6;
      const fromLeft = Math.random() < 0.5;
      comet.style.cssText = `
        position:absolute;
        left:${fromLeft ? 0 : Math.random() * window.innerWidth}px;
        top:${fromLeft ? Math.random() * window.innerHeight : 0}px;
        width:${size}px;height:${size}px;
        border-radius:50%;
        background:rgba(255,255,255,0.7);
        box-shadow:0 0 10px 3px rgba(27,122,82,0.25);
        filter:blur(1px);
      `;
      container.appendChild(comet);
      gsap.to(comet, {
        x: window.innerWidth * 1.5,
        y: window.innerHeight * 1.5,
        opacity: 0,
        duration: 3 + Math.random() * 2,
        ease: "power1.out",
        onComplete: () => comet.remove(),
      });
    };
    const iv = setInterval(createComet, 280);
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden") clearInterval(iv);
    });

    // Hero entrance
    const tl = gsap.timeline();
    tl.to("#hero-eyebrow",  { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" }, 0)
      .to("#hero-title",    { y: "0%",  duration: 0.9, ease: "power4.out" }, 0.15)
      .to("#hero-title-2",  { y: "0%",  duration: 0.9, ease: "power4.out" }, 0.25)
      .to("#hero-desc",     { opacity: 1, y: 0, duration: 0.7, ease: "power3.out" }, 0.4)
      .to("#hero-cta",      { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" }, 0.55)
      .to("#hero-image",    { opacity: 1, scale: 1, duration: 1.1, ease: "power3.out" }, 0.2)
      .to("#hero-stats",    { opacity: 1, duration: 0.8, ease: "power2.out" }, 0.7);
  });
</script>
