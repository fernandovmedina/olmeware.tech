---
const { text = "OLMEWARE" } = Astro.props;
---

<astro-divider text={text}>
  <h2 class="relative text-5xl font-semibold z-10 font-dm">{text}</h2>
</astro-divider>

<script type="module">
  class AstroDivider extends HTMLElement {
    connectedCallback() {
      const text = this.getAttribute("text") || "OLMEWARE";
      this.innerHTML = `
        <div class="relative h-[130px] flex items-center justify-center overflow-hidden bg-[#0A0806] text-[#F0E4C8] font-dm">
          <div class="absolute w-full overflow-hidden marquee-container">
            <div class="marquee-wrapper flex whitespace-nowrap text-[10vw] font-extrabold opacity-[0.04] select-none uppercase will-change-transform" style="color:#C9872A">
              <div class="marquee flex">
                ${Array(6).fill(`<span class="mx-8">${text}</span>`).join("")}
              </div>
              <div class="marquee flex" aria-hidden="true">
                ${Array(6).fill(`<span class="mx-8">${text}</span>`).join("")}
              </div>
            </div>
          </div>
          <div class="relative z-10 text-center">
            <div class="w-8 h-px bg-[#C9872A] mx-auto mb-3 opacity-60"></div>
            <h2 class="text-3xl md:text-4xl font-semibold text-[#F0E4C8] font-dm tracking-wide">${text}</h2>
            <div class="w-8 h-px bg-[#C9872A] mx-auto mt-3 opacity-60"></div>
          </div>
        </div>
      `;

      const marquee = this.querySelector(".marquee-wrapper");
      let velocity = 0.6;
      let current = 0;
      let lastScroll = window.scrollY;

      const loop = () => {
        current += velocity;
        if (current >= marquee.offsetWidth / 2) current = 0;
        marquee.style.transform = `translateX(${-current}px)`;
        requestAnimationFrame(loop);
      };
      loop();

      window.addEventListener("scroll", () => {
        const delta = window.scrollY - lastScroll;
        velocity = Math.min(5, Math.max(0.4, Math.abs(delta) * 0.4));
        lastScroll = window.scrollY;
      });

      const friction = () => {
        velocity = velocity > 0.6 ? velocity * 0.92 : 0.6;
        requestAnimationFrame(friction);
      };
      friction();
    }
  }

  if (!customElements.get("astro-divider")) {
    customElements.define("astro-divider", AstroDivider);
  }
</script>
