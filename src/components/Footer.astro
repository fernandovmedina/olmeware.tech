---
import Image from "astro/components/Image.astro";
import logoTransparent from "../assets/logo_bg_transparent.png";

const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0A0806] border-t border-[rgba(201,135,42,0.15)] px-6 md:px-14 lg:px-20 py-12">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row items-start justify-between gap-10">

      <!-- Brand -->
      <div class="max-w-xs">
        <Image src={logoTransparent} alt="OLMEWARE" width={140} height={36} class="mb-4" />
        <p class="text-sm text-[#8A7560] leading-relaxed">
          Software a la medida para empresas mexicanas. Automatización, inteligencia artificial y desarrollo a medida.
        </p>
        <!-- Social icons -->
        <div class="flex gap-3 mt-5">
          <a href="https://instagram.com/olmeware" target="_blank" class="social-icon">
            <Image src="/icons/instagram.png" alt="Instagram" width={20} height={20} />
          </a>
          <a href="https://facebook.com/olmeware" target="_blank" class="social-icon">
            <Image src="/icons/facebook.png" alt="Facebook" width={20} height={20} />
          </a>
          <a href="" class="social-icon">
            <Image src="/icons/linkedin.png" alt="LinkedIn" width={20} height={20} />
          </a>
          <a href="" class="social-icon">
            <Image src="/icons/tiktok.png" alt="TikTok" width={20} height={20} />
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div class="flex flex-wrap gap-14">
        <div>
          <h4 class="text-xs font-bold tracking-[0.15em] uppercase text-[#C9872A] mb-4">Empresa</h4>
          <ul class="space-y-2">
            <li><a href="/sobre_nosotros" class="footer-link">Quiénes Somos</a></li>
            <li><a href="/proyectos" class="footer-link">Proyectos</a></li>
            <li><a href="" class="footer-link">Blog</a></li>
            <li><a href="" class="footer-link">Bolsa de Trabajo</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-bold tracking-[0.15em] uppercase text-[#C9872A] mb-4">Servicios</h4>
          <ul class="space-y-2">
            <li><a href="/servicios" class="footer-link">Desarrollo Web</a></li>
            <li><a href="/servicios" class="footer-link">Apps Móviles</a></li>
            <li><a href="/servicios" class="footer-link">Automatización</a></li>
            <li><a href="/servicios" class="footer-link">Inteligencia Artificial</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-bold tracking-[0.15em] uppercase text-[#C9872A] mb-4">Contacto</h4>
          <ul class="space-y-2">
            <li><a href="/contacto" class="footer-link">Solicitar Demo</a></li>
            <li><a href="tel:528448580335" class="footer-link">+52 (844) 858-0335</a></li>
            <li><a href="mailto:hola@olmeware.tech" class="footer-link">hola@olmeware.tech</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-[rgba(201,135,42,0.1)] flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-[#8A7560] font-mono">
        © {currentYear} <span class="text-[#C9872A] font-bold">OLMEWARE</span>. Todos los derechos reservados.
      </p>
      <p class="text-xs text-[#8A7560] font-mono">Saltillo, Coahuila · México</p>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    font-size: 0.85rem;
    color: rgba(240, 228, 200, 0.45);
    text-decoration: none;
    transition: color 0.2s;
    display: block;
  }
  .footer-link:hover { color: #F0E4C8; }

  .social-icon {
    width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 0.4rem;
    border: 1px solid rgba(201, 135, 42, 0.2);
    background: rgba(201, 135, 42, 0.05);
    transition: border-color 0.2s, background 0.2s;
    opacity: 0.6;
  }
  .social-icon:hover {
    border-color: rgba(201, 135, 42, 0.5);
    background: rgba(201, 135, 42, 0.1);
    opacity: 1;
  }
</style>
