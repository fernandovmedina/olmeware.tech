<style>
  #custom-cursor {
    position: fixed;
    top: 0; left: 0;
    z-index: 9999;
    width: 36px; height: 36px;
    border-radius: 50%;
    background-color: #F0E4C8;
    pointer-events: none;
    transform: translate(-50%, -50%);
    mix-blend-mode: difference;
  }
</style>

<div id="custom-cursor"></div>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const cursor = document.getElementById("custom-cursor");
    if (!cursor) return;

    document.addEventListener("mousemove", (e) => {
      gsap.to(cursor, { x: e.clientX, y: e.clientY, duration: 0.15, ease: "power2.out" });
    });

    document.addEventListener("click", () => {
      gsap.to(cursor, {
        scale: 2, duration: 0.2, ease: "back.out(1.7)",
        onComplete: () => gsap.to(cursor, { scale: 1, duration: 0.3 }),
      });
    });

    const beat = gsap.to(cursor, {
      scale: 0.5, repeat: -1, yoyo: true, duration: 0.3,
      ease: "power1.inOut", paused: true,
    });

    document.querySelectorAll("a, button").forEach((el) => {
      el.addEventListener("mouseenter", () => { beat.restart(); beat.play(); });
      el.addEventListener("mouseleave", () => {
        beat.pause();
        gsap.to(cursor, { scale: 1, duration: 0.2, ease: "power1.out" });
      });
    });
  });
</script>
